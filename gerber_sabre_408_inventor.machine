  <axis actuator="linear" coordinate="X" homePosition="0mm" id="X" link="table" maximumFeed="21590mm/min" name="X" offset="0mm 0mm 0mm" range="0mm 1370mm" rapidFeed="21590mm/min" resolution="0mm"/>

  <axis actuator="linear" coordinate="Y" homePosition="0mm" id="Y" link="table" maximumFeed="21590mm/min" name="Y" offset="0mm 0mm 0mm" range="0mm 2540mm" rapidFeed="21590mm/min" resolution="0mm"/>

  <axis actuator="linear" coordinate="Z" homePosition="0mm" id="Z" link="table" maximumFeed="21590mm/min" name="Z" offset="0mm 0mm 0mm" range="-190mm 0mm" rapidFeed="21590mm/min" resolution="0mm"/>

  <spindle axis="0 0 1" maximumSpeed="24000rpm" minimumSpeed="5000rpm">
